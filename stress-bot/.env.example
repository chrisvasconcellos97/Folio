# Copy to .env and fill in. .env is gitignored.

# Target app — change this to point at any deployed app
TARGET_URL=https://folioshq.com

# Test user creds (create a dedicated stress-test account, never your real one)
TEST_USER_EMAIL=stress-bot@example.com
TEST_USER_PASSWORD=replace-me

# Optional — direct Supabase access for RLS boundary tests
# Leave blank to skip the RLS scenario.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional — a *second* test user, used only by the RLS scenario to
# verify user A cannot read user B's rows. Leave blank to skip.
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=
